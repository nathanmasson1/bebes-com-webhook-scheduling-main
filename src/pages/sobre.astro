---
import BaseLayout from '../layouts/BaseLayout.astro';
import { readData } from '../lib/readData';

const sobre = readData('sobre.json') || {};
const seo = sobre.seo || {};
const hero = sobre.hero || {};
const story = sobre.story || {};
const values = sobre.values || {};
const timelineSec = sobre.timeline || {};
const cta = sobre.cta || {};

const valueItems = values.items || [];
const timeline = timelineSec.items || [];
const storyParagraphs = story.paragraphs || [];
const storyStats = story.stats || [];
---

<BaseLayout
  title={seo.title || 'Sobre'}
  description={seo.description || 'Conheca o Ninho & Colo, um blog sobre maternidade, bebes, enxoval e rotina familiar.'}
  image={seo.image || undefined}
>
  <!-- Hero -->
  <section class="about-hero">
    <div class="about-hero-bg"></div>
    <div class="container about-hero-inner">
      <span class="section-label">{hero.label || 'Sobre Nós'}</span>
      <h1 class="about-hero-title">
        {hero.title || 'Ajudamos você a fazer'}
        <span class="about-hero-accent">{hero.titleAccent || 'escolhas inteligentes'}</span>
      </h1>
      <p class="about-hero-subtitle">{hero.subtitle}</p>
    </div>
  </section>

  <!-- Story -->
  <section class="about-story section">
    <div class="container">
      <div class="story-grid">
        <div class="story-content animate-on-scroll">
          <span class="section-label">{story.label || 'Nossa História'}</span>
          <h2 class="story-title">
            {story.title}
            <span class="story-accent">{story.titleAccent}</span>
          </h2>
          {storyParagraphs.map((p: string) => (
            <p class="story-text" set:html={p}></p>
          ))}
        </div>

        <div class="story-stats animate-on-scroll">
          {storyStats.map((s: any) => (
            <div class="story-stat-card">
              <span class="story-stat-number">{s.number}</span>
              <span class="story-stat-label">{s.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="about-values section">
    <div class="container">
      <div class="section-header animate-on-scroll">
        <span class="section-label">{values.label || 'Nossos Valores'}</span>
        <h2 class="section-title">{values.title || 'O que nos guia'}</h2>
        <p class="section-subtitle">{values.subtitle}</p>
      </div>

      <div class="values-grid stagger-children animate-on-scroll">
        {valueItems.map((value: any) => (
          <div class="value-card">
            <span class="value-number">{value.number}</span>
            <h3 class="value-title">{value.title}</h3>
            <p class="value-text">{value.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="about-timeline section">
    <div class="container">
      <div class="section-header animate-on-scroll">
        <span class="section-label">{timelineSec.label || 'Linha do Tempo'}</span>
        <h2 class="section-title">{timelineSec.title || 'Nossa jornada'}</h2>
      </div>

      <div class="timeline stagger-children animate-on-scroll">
        {timeline.map((item: any) => (
          <div class="timeline-item">
            <div class="timeline-marker">
              <span class="timeline-year">{item.year}</span>
            </div>
            <div class="timeline-content">
              <h3 class="timeline-title">{item.title}</h3>
              <p class="timeline-text">{item.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="about-cta section">
    <div class="container about-cta-inner animate-on-scroll">
      <h2 class="about-cta-title">
        {cta.title || 'Pronto para descobrir os'}
        <span class="about-cta-accent">{cta.titleAccent || 'melhores produtos?'}</span>
      </h2>
      <p class="about-cta-text">{cta.text}</p>
      <div class="about-cta-actions">
        <a href={(cta.ctaPrimary && cta.ctaPrimary.href) || '/blog'} class="btn btn-primary">
          {(cta.ctaPrimary && cta.ctaPrimary.text) || 'Ver Blog'}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href={(cta.ctaSecondary && cta.ctaSecondary.href) || '/contato'} class="btn btn-outline">{(cta.ctaSecondary && cta.ctaSecondary.text) || 'Fale Conosco'}</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .about-hero {
    position: relative;
    padding: calc(var(--navbar-height) + var(--space-4xl)) 0 var(--space-4xl);
    text-align: center;
    overflow: hidden;
  }

  .about-hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-bg-warm), var(--color-bg-cool));
    z-index: -1;
  }

  .about-hero-title {
    font-family: var(--font-heading);
    font-size: var(--fs-5xl);
    font-weight: var(--fw-extrabold);
    letter-spacing: 0;
    margin-bottom: var(--space-xl);
    line-height: var(--lh-tight);
  }

  .about-hero-accent {
    display: block;
    font-family: var(--font-display);
    font-weight: var(--fw-regular);
    font-style: italic;
    color: var(--color-primary);
    letter-spacing: 0;
  }

  .about-hero-subtitle {
    font-size: var(--fs-lg);
    color: var(--color-text-muted);
    max-width: 560px;
    margin: 0 auto;
    line-height: var(--lh-relaxed);
    font-weight: var(--fw-light);
  }

  /* Story */
  .about-story {
    background: var(--color-bg);
  }

  .story-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-4xl);
    align-items: start;
  }

  .story-title {
    font-family: var(--font-heading);
    font-size: var(--fs-3xl);
    font-weight: var(--fw-extrabold);
    letter-spacing: var(--ls-tight);
    margin-bottom: var(--space-xl);
    line-height: var(--lh-snug);
    text-align: left;
  }

  .story-accent {
    font-family: var(--font-display);
    font-weight: var(--fw-regular);
    font-style: italic;
    color: var(--color-primary);
  }

  .story-text {
    font-size: var(--fs-md);
    color: var(--color-text-secondary);
    line-height: var(--lh-relaxed);
    margin-bottom: var(--space-lg);
    font-weight: var(--fw-light);
  }

  .story-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }

  .story-stat-card {
    padding: var(--space-xl);
    background: var(--color-bg-warm);
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-border-light);
    text-align: center;
    transition: all var(--transition-base);
  }

  .story-stat-card:hover {
    border-color: var(--color-border);
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }

  .story-stat-number {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--fs-2xl);
    font-weight: var(--fw-extrabold);
    color: var(--color-primary);
    letter-spacing: var(--ls-tight);
    margin-bottom: 4px;
  }

  .story-stat-label {
    font-size: var(--fs-xs);
    color: var(--color-text-faint);
    text-transform: uppercase;
    letter-spacing: var(--ls-wider);
  }

  /* Values */
  .about-values {
    background: var(--color-bg-warm);
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl);
  }

  .value-card {
    padding: var(--space-2xl);
    background: var(--color-bg-pure);
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-border-light);
    position: relative;
    overflow: hidden;
    transition: all var(--transition-base);
    animation: fadeInUp 500ms var(--ease-out-expo) both;
  }

  .value-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--color-primary);
    border-radius: 0 3px 3px 0;
    transform: scaleY(0);
    transition: transform var(--transition-base);
    transform-origin: center;
  }

  .value-card:hover {
    border-color: var(--color-border);
    box-shadow: var(--shadow-md);
  }

  .value-card:hover::before {
    transform: scaleY(1);
  }

  .value-number {
    font-family: var(--font-display);
    font-size: var(--fs-3xl);
    font-style: italic;
    color: var(--color-primary-lighter);
    line-height: 1;
    display: block;
    margin-bottom: var(--space-md);
    transition: color var(--transition-base);
  }

  .value-card:hover .value-number {
    color: var(--color-primary-light);
  }

  .value-title {
    font-family: var(--font-heading);
    font-size: var(--fs-lg);
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-tight);
    margin-bottom: var(--space-sm);
  }

  .value-text {
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
    line-height: var(--lh-relaxed);
    font-weight: var(--fw-light);
  }

  /* Timeline */
  .about-timeline {
    background: var(--color-bg);
  }

  .timeline {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 43px;
    top: 0;
    bottom: 0;
    width: 1px;
    background: var(--color-border);
  }

  .timeline-item {
    display: flex;
    gap: var(--space-2xl);
    padding-bottom: var(--space-2xl);
    position: relative;
    animation: fadeInUp 500ms var(--ease-out-expo) both;
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  .timeline-marker {
    flex-shrink: 0;
    width: 86px;
    display: flex;
    justify-content: center;
  }

  .timeline-year {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.35rem 0.85rem;
    background: var(--color-primary);
    color: #fff;
    font-size: var(--fs-xs);
    font-weight: var(--fw-bold);
    border-radius: var(--radius-full);
    letter-spacing: var(--ls-wide);
    position: relative;
    z-index: 1;
  }

  .timeline-content {
    padding-top: 2px;
  }

  .timeline-title {
    font-family: var(--font-heading);
    font-size: var(--fs-lg);
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-tight);
    margin-bottom: var(--space-xs);
  }

  .timeline-text {
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
    line-height: var(--lh-relaxed);
    font-weight: var(--fw-light);
  }

  /* CTA */
  .about-cta {
    background: var(--color-bg-warm);
  }

  .about-cta-inner {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .about-cta-title {
    font-family: var(--font-heading);
    font-size: var(--fs-3xl);
    font-weight: var(--fw-extrabold);
    letter-spacing: var(--ls-tight);
    margin-bottom: var(--space-lg);
    line-height: var(--lh-tight);
  }

  .about-cta-accent {
    font-family: var(--font-display);
    font-weight: var(--fw-regular);
    font-style: italic;
    color: var(--color-primary);
  }

  .about-cta-text {
    font-size: var(--fs-md);
    color: var(--color-text-muted);
    margin-bottom: var(--space-2xl);
    font-weight: var(--fw-light);
  }

  .about-cta-actions {
    display: flex;
    justify-content: center;
    gap: var(--space-md);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .story-grid {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }

    .story-title {
      text-align: center;
    }

    .story-content {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .values-grid {
      grid-template-columns: 1fr;
    }

    .timeline::before {
      display: none;
    }

    .timeline-item {
      flex-direction: column;
      gap: var(--space-sm);
      align-items: flex-start;
    }

    .timeline-marker {
      width: auto;
    }

    .about-cta-actions {
      flex-direction: column;
      align-items: center;
    }
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import AffiliateDisclosure from '../components/affiliate/AffiliateDisclosure.astro';
import ComparisonTable from '../components/affiliate/ComparisonTable.astro';
import StickyProductSidebar from '../components/affiliate/StickyProductSidebar.astro';
import ProductReviewCard from '../components/affiliate/ProductReviewCard.astro';
import TableOfContents from '../components/TableOfContents.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import PostBottomPlugins from '../plugins/_slots/PostBottomPlugins.astro';
import { isPostPublic } from '../lib/postVisibility';
import { readData } from '../lib/readData';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => isPostPublic(data));
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const formattedDate = post.data.pubDate.toLocaleDateString('pt-BR', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});

const formattedUpdatedDate = post.data.updatedDate?.toLocaleDateString('pt-BR', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});

const categoryLabels: Record<string, string> = {
  'gravidez': 'Gravidez',
  'recem-nascido': 'Recem-nascido',
  'sono-do-bebe': 'Sono do bebe',
  'enxoval': 'Enxoval',
  'amamentacao': 'Amamentacao',
  'rotina-familiar': 'Rotina familiar',
  'produtos-fisicos': 'Produtos Físicos',
  'produtos-digitais': 'Produtos Digitais',
  'reviews': 'Guias',
  'dicas': 'Dicas',
  'comparativos': 'Comparativos',
  'produtos-fisicos': 'Enxoval',
  'produtos-digitais': 'Rotina familiar',
};

const products = post.data.products || [];
const featuredProduct = products.find((p) => p.featured) || products[0] || null;
const hasProducts = products.length > 0;
const hasLegacyLink = !hasProducts && !!post.data.affiliateLink;
const authors = readData<any[]>('authors.json', []);
const authorInfo = authors.find((author) => author.name === post.data.author) || {
  name: post.data.author,
  role: 'Autoria',
  bio: '',
  avatar: '',
};
const authorInitial = (authorInfo.name || post.data.author || '?').charAt(0).toUpperCase();

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Guias', url: '/blog' },
  { name: categoryLabels[post.data.category] || post.data.category, url: `/blog` },
];
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.image}
  type="article"
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  author={post.data.author}
  rating={post.data.rating}
  products={products}
  breadcrumbs={breadcrumbs}
>
  <article class="post">
    <header class="post-header">
      <div class="post-header-bg"></div>
      <div class="container post-header-inner">
        <nav class="post-breadcrumb" aria-label="Breadcrumb">
          {breadcrumbs.map((crumb, i) => (
            <>
              {i > 0 && <span class="post-breadcrumb-sep">/</span>}
              {i < breadcrumbs.length - 1 ? (
                <a href={crumb.url}>{crumb.name}</a>
              ) : (
                <span>{crumb.name}</span>
              )}
            </>
          ))}
        </nav>

        <div class="post-meta">
          <span class="post-category">{categoryLabels[post.data.category] || post.data.category}</span>
          <time datetime={post.data.pubDate.toISOString()}>{formattedDate}</time>
          {formattedUpdatedDate && (
            <>
              <span class="post-meta-dot">·</span>
              <span class="post-updated">Atualizado: {formattedUpdatedDate}</span>
            </>
          )}
          <span class="post-meta-dot">·</span>
          <span>Por {post.data.author}</span>
        </div>

        <h1 class="post-title">{post.data.title}</h1>
        <p class="post-description">{post.data.description}</p>

        {post.data.tags.length > 0 && (
          <div class="post-tags">
            {post.data.tags.map((tag) => (
              <span class="post-tag">#{tag}</span>
            ))}
          </div>
        )}
      </div>
    </header>

    {post.data.image && (
      <div class="container">
        <div class="post-image">
          <img src={post.data.image} alt={post.data.imageAlt || post.data.title} />
        </div>
      </div>
    )}

    <div class="container">
      {post.data.showDisclosure && (hasProducts || hasLegacyLink) && (
        <div class="post-disclosure">
          <AffiliateDisclosure variant="inline" />
        </div>
      )}

      <div class:list={['post-layout', { 'post-layout-sidebar': post.data.showToc || featuredProduct }]}>
        {/* Sidebar */}
        {(post.data.showToc || featuredProduct) && (
          <aside class="post-sidebar">
            {post.data.showToc && <TableOfContents headings={headings} variant="desktop" />}
            {featuredProduct && (
              <div class="sidebar-product">
                <StickyProductSidebar
                  name={featuredProduct.name}
                  price={featuredProduct.price}
                  rating={featuredProduct.rating}
                  affiliateLink={featuredProduct.affiliateLink}
                  store={featuredProduct.store}
                  badge={featuredProduct.badge}
                />
              </div>
            )}
          </aside>
        )}

        {/* Main content */}
        <div class="post-content-area">
          {/* Mobile TOC */}
          {post.data.showToc && <TableOfContents headings={headings} variant="mobile" />}

          {/* 1. Intro (article body markdown) */}
          <div class="post-content">
            <Content />
          </div>

          {/* 2. Product Review Cards (all products) */}
          {products.length > 0 && (
            <div class="post-products-section">
              <div class="post-products-header">
                <h3 class="post-products-title">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><polyline points="17 11 19 13 23 9"/></svg>
                  {products.length === 1 ? 'Nosso Veredito' : `Análise dos ${products.length} Produtos`}
                </h3>
                <p class="post-products-subtitle">Review detalhado com prós e contras de cada produto avaliado.</p>
              </div>
              {products.map((product, i) => (
                <ProductReviewCard
                  name={product.name}
                  description={product.description}
                  review={product.review}
                  price={product.price}
                  originalPrice={product.originalPrice}
                  rating={product.rating}
                  affiliateLink={product.affiliateLink}
                  store={product.store}
                  image={product.image}
                  badge={product.badge}
                  pros={product.pros}
                  cons={product.cons}
                  index={i + 1}
                />
              ))}
            </div>
          )}

          {/* 3. Comparison Table */}
          {products.length > 1 && (
            <ComparisonTable products={products} />
          )}

          {/* 4. FAQ */}
          {post.data.faqs && post.data.faqs.length > 0 && (
            <section class="post-faq-section" id="faq">
              <h2 class="post-faq-title">Perguntas Frequentes</h2>
              <div class="post-faq-list">
                {post.data.faqs.map((faq) => (
                  <details class="post-faq-item">
                    <summary class="post-faq-q">{faq.q}</summary>
                    <div class="post-faq-a">{faq.a}</div>
                  </details>
                ))}
              </div>
            </section>
          )}

          {/* 5. Veredito Final */}
          {post.data.conclusion && (
            <section class="post-verdict" id="veredito">
              <h2 class="post-verdict-title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
                Veredito Final
              </h2>
              <div class="post-verdict-content">
                {post.data.conclusion.split(/\n\n+/).map((p) => <p>{p}</p>)}
              </div>
            </section>
          )}

          {/* Bottom CTA: legacy fallback */}
          {hasLegacyLink && (
            <div class="post-affiliate-cta">
              <div class="post-affiliate-badge">Recomendação</div>
              <p class="post-affiliate-text">Gostou deste produto? Confira o melhor preço:</p>
              <a href={post.data.affiliateLink} class="btn btn-secondary" target="_blank" rel="sponsored noopener">
                Ver Produto
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3"/></svg>
              </a>
            </div>
          )}

          <aside class="author-box" aria-label={`Sobre o autor ${authorInfo.name}`}>
            <div class="author-avatar">
              {authorInfo.avatar ? (
                <img src={authorInfo.avatar} alt={authorInfo.name} loading="lazy" />
              ) : (
                <span>{authorInitial}</span>
              )}
            </div>
            <div class="author-content">
              <p class="author-kicker">Sobre o autor</p>
              <h2 class="author-name">{authorInfo.name}</h2>
              {authorInfo.role && <p class="author-role">{authorInfo.role}</p>}
              {authorInfo.bio && <p class="author-bio">{authorInfo.bio}</p>}
            </div>
          </aside>

          <div class="post-bottom-plugins">
            <PostBottomPlugins title={post.data.title} />
          </div>
        </div>
      </div>

      {/* Related Posts */}
      <RelatedPosts currentCategory={post.data.category} currentSlug={post.id} />
    </div>

    <nav class="container post-nav">
      <div class="post-nav-line"></div>
      <a href="/blog" class="btn btn-outline">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        Voltar aos guias
      </a>
    </nav>
  </article>
</BaseLayout>

<style>
  /* Header */
  .post-header {
    position: relative;
    padding: calc(var(--navbar-height) + var(--space-3xl)) 0 var(--space-3xl);
    overflow: hidden;
  }

  .post-header-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-bg-warm), var(--color-bg-cool));
    z-index: -1;
  }

  .post-header-inner {
    max-width: var(--container-narrow);
  }

  .post-breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--fs-xs);
    color: var(--color-text-faint);
    margin-bottom: var(--space-2xl);
    letter-spacing: var(--ls-wide);
  }

  .post-breadcrumb a {
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }

  .post-breadcrumb a:hover { color: var(--color-primary); }
  .post-breadcrumb-sep { opacity: 0.3; }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
    flex-wrap: wrap;
  }

  .post-meta-dot { opacity: 0.3; }

  .post-updated {
    font-style: italic;
    color: var(--color-primary-light);
  }

  .post-category {
    padding: 0.3rem 0.85rem;
    background: var(--color-primary-surface);
    color: var(--color-primary);
    border-radius: var(--radius-full);
    font-size: 0.7rem;
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: var(--ls-wider);
    border: 1px solid var(--color-primary-lighter);
  }

  .post-title {
    font-family: var(--font-heading);
    font-size: var(--fs-5xl);
    font-weight: var(--fw-extrabold);
    line-height: var(--lh-tight);
    letter-spacing: 0;
    margin-bottom: var(--space-xl);
  }

  .post-description {
    font-size: var(--fs-lg);
    color: var(--color-text-secondary);
    line-height: var(--lh-relaxed);
    margin-bottom: var(--space-xl);
    font-weight: var(--fw-light);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .post-tag {
    font-size: var(--fs-sm);
    color: var(--color-primary-light);
    font-weight: var(--fw-medium);
  }

  /* Featured image */
  .post-image {
    max-width: var(--container-narrow);
    margin: 0 auto;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-xl);
    margin-top: calc(-1 * var(--space-xl));
    margin-bottom: var(--space-3xl);
    border: 1px solid var(--color-border-light);
  }

  .post-image img { width: 100%; height: auto; }

  /* Disclosure */
  .post-disclosure {
    max-width: var(--container-narrow);
    margin: 0 auto var(--space-lg);
  }

  /* Layout with sidebar */
  .post-layout {
    max-width: var(--container-narrow);
    margin: 0 auto;
  }

  @media (min-width: 1280px) {
    .post-layout-sidebar {
      display: grid;
      grid-template-columns: 220px 1fr;
      gap: var(--space-3xl);
      max-width: 100%;
    }

    .post-layout-sidebar .post-content-area {
      max-width: var(--container-narrow);
    }
  }

  /* Sidebar */
  .post-sidebar {
    display: none;
  }

  @media (min-width: 1280px) {
    .post-sidebar {
      display: flex;
      flex-direction: column;
      gap: var(--space-2xl);
      padding-top: var(--space-xl);
    }
  }

  .sidebar-product {
    margin-top: var(--space-md);
  }

  /* Content area */
  .post-content-area {
    min-width: 0;
  }

  /* Content prose */
  .post-content {
    padding: var(--space-2xl) 0;
  }

  .post-content :global(h2) {
    font-family: var(--font-heading);
    font-size: var(--fs-2xl);
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-tight);
    margin-top: var(--space-3xl);
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-border-light);
  }

  .post-content :global(h3) {
    font-family: var(--font-heading);
    font-size: var(--fs-xl);
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-tight);
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
  }

  .post-content :global(p) {
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    margin-bottom: var(--space-lg);
    color: var(--color-text-secondary);
    font-weight: var(--fw-light);
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin-bottom: var(--space-lg);
    padding-left: var(--space-xl);
  }

  .post-content :global(li) {
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    margin-bottom: var(--space-sm);
    color: var(--color-text-secondary);
    list-style: disc;
    font-weight: var(--fw-light);
  }

  .post-content :global(ol li) { list-style: decimal; }

  .post-content :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding: var(--space-lg) var(--space-xl);
    margin: var(--space-xl) 0;
    background: var(--color-accent-surface);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }

  .post-content :global(blockquote p) {
    margin-bottom: 0;
    font-style: italic;
    color: var(--color-text);
    font-weight: var(--fw-regular);
  }

  .post-content :global(img) {
    border-radius: var(--radius-lg);
    margin: var(--space-xl) 0;
    box-shadow: var(--shadow-md);
  }

  .post-content :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-decoration-color: var(--color-primary-lighter);
    text-underline-offset: 3px;
    transition: text-decoration-color var(--transition-fast);
  }

  .post-content :global(a:hover) { text-decoration-color: var(--color-primary); }

  .post-content :global(strong) {
    color: var(--color-text);
    font-weight: var(--fw-semibold);
  }

  .post-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-xl) 0;
    font-size: var(--fs-sm);
  }

  .post-content :global(th) {
    text-align: left;
    padding: var(--space-md);
    background: var(--color-bg-cool);
    font-weight: var(--fw-semibold);
    border-bottom: 2px solid var(--color-border);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: var(--ls-wider);
    color: var(--color-text-secondary);
  }

  .post-content :global(td) {
    padding: var(--space-md);
    border-bottom: 1px solid var(--color-border-light);
    color: var(--color-text-secondary);
    font-weight: var(--fw-light);
  }

  .post-content :global(tr:hover td) { background: var(--color-bg-warm); }

  /* Inline CTA slot */
  .inline-cta-slot {
    display: none;
  }

  .inline-cta-slot.placed {
    display: block;
  }

  /* Products section */
  .post-products-section {
    margin: var(--space-2xl) 0;
    padding-top: var(--space-xl);
    border-top: 2px solid var(--color-primary-surface);
  }

  .post-products-header {
    margin-bottom: var(--space-xl);
  }

  .post-products-title {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-heading);
    font-size: var(--fs-xl);
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-tight);
    margin-bottom: var(--space-xs);
    color: var(--color-text);
  }

  .post-products-title svg {
    color: var(--color-primary);
  }

  .post-products-subtitle {
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
    font-weight: var(--fw-light);
  }

  /* FAQ Section */
  .post-faq-section {
    margin: var(--space-3xl) 0;
    padding-top: var(--space-2xl);
    border-top: 2px solid var(--color-primary-surface);
  }

  .post-faq-title {
    font-family: var(--font-heading);
    font-size: var(--fs-2xl);
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-tight);
    margin-bottom: var(--space-xl);
    color: var(--color-text);
  }

  .post-faq-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .post-faq-item {
    background: var(--color-bg-pure);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all var(--transition-base);
  }

  .post-faq-item[open] {
    border-color: var(--color-primary-lighter);
    box-shadow: var(--shadow-sm);
    background: var(--color-primary-surface);
  }

  .post-faq-q {
    padding: var(--space-lg) var(--space-xl);
    font-size: var(--fs-md);
    font-weight: var(--fw-semibold);
    color: var(--color-text);
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .post-faq-q::-webkit-details-marker { display: none; }

  .post-faq-q::after {
    content: '+';
    font-size: var(--fs-xl);
    font-weight: var(--fw-light);
    color: var(--color-primary);
    flex-shrink: 0;
    transition: transform var(--transition-base);
  }

  .post-faq-item[open] .post-faq-q::after {
    transform: rotate(45deg);
  }

  .post-faq-a {
    padding: 0 var(--space-xl) var(--space-lg);
    font-size: var(--fs-md);
    color: var(--color-text-secondary);
    line-height: var(--lh-relaxed);
    font-weight: var(--fw-light);
    white-space: pre-wrap;
  }

  /* Veredito Final */
  .post-verdict {
    margin: var(--space-3xl) 0;
    padding: var(--space-2xl) var(--space-3xl);
    background: linear-gradient(135deg, var(--color-primary-surface), var(--color-bg-warm));
    border: 1px solid var(--color-primary-lighter);
    border-radius: var(--radius-xl);
    position: relative;
  }

  .post-verdict-title {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-heading);
    font-size: var(--fs-2xl);
    font-weight: var(--fw-extrabold);
    letter-spacing: var(--ls-tight);
    margin-bottom: var(--space-lg);
    color: var(--color-primary);
  }

  .post-verdict-content p {
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    margin-bottom: var(--space-md);
    color: var(--color-text);
    font-weight: var(--fw-regular);
  }

  .post-verdict-content p:last-child { margin-bottom: 0; }

  /* Legacy affiliate CTA */
  .post-affiliate-cta {
    max-width: var(--container-narrow);
    margin: var(--space-2xl) 0;
    padding: var(--space-2xl) var(--space-3xl);
    background: linear-gradient(135deg, var(--color-accent-surface), var(--color-warm-light));
    border-radius: var(--radius-xl);
    text-align: center;
    border: 1px solid var(--color-accent-light);
    position: relative;
  }

  .post-affiliate-badge {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.65rem;
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: var(--ls-widest);
    color: #fff;
    background: var(--color-accent);
    padding: 0.25rem 1rem;
    border-radius: var(--radius-full);
  }

  .post-affiliate-text {
    font-size: var(--fs-md);
    font-weight: var(--fw-medium);
    margin-bottom: var(--space-lg);
    color: var(--color-text);
  }

  .author-box {
    display: grid;
    grid-template-columns: 92px 1fr;
    align-items: center;
    gap: var(--space-xl);
    margin: var(--space-2xl) 0;
    padding: var(--space-xl);
    background: var(--color-bg-pure);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-sm);
  }


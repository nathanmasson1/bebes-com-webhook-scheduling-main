---
interface Props {
  data?: any;
}

const d = Astro.props.data || {};
const badge = d.badge || 'Maternidade com calma e informacao';
const title = d.title || 'Um cantinho seguro para viver a maternidade com mais leveza';
const subtitle = d.subtitle || 'Guias praticos sobre gravidez, enxoval, sono, amamentacao, cuidados com o bebe e rotina familiar.';
const ctaPrimary = d.ctaPrimary || { text: 'Ver guias', href: '/blog' };
const ctaSecondary = d.ctaSecondary || { text: 'Conhecer o projeto', href: '/sobre' };
const heroImage = d.image || '/images/maternity-hero.png';
const stats = d.stats || [
  { number: '0-2', label: 'anos do bebe' },
  { number: '40+', label: 'temas essenciais' },
  { number: '100%', label: 'acolhimento' },
];
---

<section class="hero">
  <div class="hero-bg">
    <div class="hero-gradient"></div>
    <div class="hero-pattern"></div>
  </div>

  <div class="container hero-inner">
    <div class="hero-content">
      <div class="hero-badge">
        <span class="hero-badge-dot"></span>
        {badge}
      </div>

      <h1 class="hero-title">{title}</h1>

      <p class="hero-subtitle">{subtitle}</p>

      <div class="hero-actions">
        <a href={ctaPrimary.href} class="btn btn-primary btn-lg">
          {ctaPrimary.text}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href={ctaSecondary.href} class="btn btn-ghost">
          {ctaSecondary.text}
        </a>
      </div>

      <div class="hero-stats">
        {stats.map((stat: any, i: number) => (
          <>
            {i > 0 && <div class="hero-stat-divider"></div>}
            <div class="hero-stat">
              <span class="hero-stat-number">{stat.number}</span>
              <span class="hero-stat-label">{stat.label}</span>
            </div>
          </>
        ))}
      </div>
    </div>

    <div class="hero-visual">
      <div class="hero-card hero-card-1">
        <div class="hero-card-icon">01</div>
        <div class="hero-card-text">
          <strong>Gravidez</strong>
          <span>preparacao sem pressa</span>
        </div>
      </div>
      <div class="hero-card hero-card-2">
        <div class="hero-card-icon">02</div>
        <div class="hero-card-text">
          <strong>Enxoval</strong>
          <span>o essencial de verdade</span>
        </div>
      </div>
      <div class="hero-card hero-card-3">
        <div class="hero-card-icon">03</div>
        <div class="hero-card-text">
          <strong>Rotina</strong>
          <span>cuidado possivel</span>
        </div>
      </div>
      <div class="hero-image-frame">
        <img src={heroImage} alt="Quarto de bebe acolhedor com enxoval em tons suaves" width="1024" height="1536" />
      </div>
    </div>
  </div>

  <div class="hero-scroll-indicator">
    <div class="hero-scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: center;
    padding-top: var(--navbar-height);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255, 240, 237, 0.92) 0%, rgba(244, 250, 246, 0.86) 52%, rgba(255, 250, 246, 1) 100%);
  }

  .hero-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.035;
    background-image:
      linear-gradient(90deg, var(--color-primary) 1px, transparent 1px),
      linear-gradient(0deg, var(--color-accent) 1px, transparent 1px);
    background-size: 36px 36px;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1.08fr 0.92fr;
    gap: var(--space-4xl);
    align-items: center;
    padding: var(--space-4xl) 0;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--fs-xs);
    font-weight: var(--fw-semibold);
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: var(--ls-widest);
    margin-bottom: var(--space-2xl);
    padding: 0.4rem 1.2rem;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid var(--color-primary-lighter);
    border-radius: var(--radius-full);
    animation: fadeInUp 600ms var(--ease-out-expo) both;
  }

  .hero-badge-dot {
    width: 7px;
    height: 7px;
    background: var(--color-accent);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: var(--fs-hero);
    font-weight: var(--fw-extrabold);
    line-height: 1.05;
    letter-spacing: 0;
    margin-bottom: var(--space-xl);
    color: var(--color-text);
    animation: fadeInUp 600ms var(--ease-out-expo) 100ms both;
  }

  .hero-subtitle {
    font-size: var(--fs-md);
    font-weight: var(--fw-light);
    color: var(--color-text-muted);
    line-height: var(--lh-relaxed);
    margin-bottom: var(--space-2xl);
    max-width: 540px;
    animation: fadeInUp 600ms var(--ease-out-expo) 200ms both;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-4xl);
    animation: fadeInUp 600ms var(--ease-out-expo) 300ms both;
  }

  .btn-lg {
    padding: 1rem 2.5rem;
    font-size: var(--fs-sm);
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
    animation: fadeInUp 600ms var(--ease-out-expo) 400ms both;
  }

  .hero-stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .hero-stat-number {
    font-family: var(--font-heading);
    font-size: var(--fs-2xl);
    font-weight: var(--fw-extrabold);
    color: var(--color-primary);
    letter-spacing: 0;
  }

  .hero-stat-label {
    font-size: var(--fs-xs);
    color: var(--color-text-faint);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
  }

  .hero-stat-divider {
    width: 1px;
    height: 36px;
    background: var(--color-border);
  }

  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 520px;
  }

  .hero-image-frame {
    width: 100%;
    max-width: 410px;
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: var(--color-bg-pure);
    box-shadow: var(--shadow-xl);
    border: 1px solid var(--color-border-light);
    animation: scaleIn 800ms var(--ease-out-expo) 300ms both;
  }

  .hero-image-frame img {
    width: 100%;
    height: 540px;
    display: block;
    object-fit: cover;
  }

  .hero-card {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 1.25rem;
    background: rgba(255, 255, 255, 0.94);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--color-border-light);
    z-index: 2;
    animation: fadeInUp 600ms var(--ease-out-expo) both;
  }

  .hero-card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--color-primary-surface);
    color: var(--color-primary);
    font-size: 0.72rem;
    font-weight: var(--fw-bold);
    line-height: 1;
  }

  .hero-card-text {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .hero-card-text strong {
    font-size: var(--fs-sm);
    font-weight: var(--fw-semibold);
    color: var(--color-text);
  }

  .hero-card-text span {
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
  }

  .hero-card-1 {
    top: 8%;
    right: -1%;
    animation-delay: 600ms;
  }

  .hero-card-2 {
    bottom: 20%;
    left: -4%;
    animation-delay: 750ms;
  }

  .hero-card-3 {
    bottom: 7%;
    right: 5%;
    animation-delay: 900ms;
  }

  .hero-scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    animation: fadeIn 1s var(--ease-out-expo) 1.2s both;
  }

  .hero-scroll-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, var(--color-primary-lighter), transparent);
    position: relative;
    overflow: hidden;
  }

  .hero-scroll-line::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 16px;
    background: var(--color-primary);
    animation: scrollDown 2s ease-in-out infinite;
  }

  @keyframes scrollDown {
    0% { transform: translateY(-16px); }
    100% { transform: translateY(48px); }
  }

  @media (max-width: 1024px) {
    .hero-card-1 { right: 0; }
    .hero-card-2 { left: -2%; }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding-top: var(--navbar-height);
    }

    .hero-inner {
      grid-template-columns: 1fr;
      gap: var(--space-3xl);
      text-align: center;
      padding: var(--space-3xl) 0 var(--space-4xl);
    }

    .hero-subtitle {
      max-width: 100%;
      margin-left: auto;
      margin-right: auto;
    }

    .hero-actions {
      justify-content: center;
      flex-wrap: wrap;
    }

    .hero-stats {
      justify-content: center;
      flex-wrap: wrap;
    }

    .hero-visual {
      display: none;
    }

    .hero-scroll-indicator {
      display: none;
    }
  }
</style>

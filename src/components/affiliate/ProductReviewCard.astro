---
import RatingStars from './RatingStars.astro';

interface Props {
  name: string;
  description?: string;
  review?: string;
  price?: string;
  originalPrice?: string;
  rating?: number;
  affiliateLink: string;
  store?: string;
  image?: string;
  badge?: string;
  pros?: string[];
  cons?: string[];
  index?: number;
}

const {
  name,
  description,
  review,
  price,
  originalPrice,
  rating,
  affiliateLink,
  store = 'outro',
  image,
  badge,
  pros = [],
  cons = [],
  index = 1,
} = Astro.props;

const storeLabels: Record<string, string> = {
  'amazon': 'Ver na Amazon',
  'hotmart': 'Acessar Curso',
  'eduzz': 'Acessar Produto',
  'monetizze': 'Acessar Produto',
  'mercado-livre': 'Ver no Mercado Livre',
  'shopee': 'Ver na Shopee',
  'outro': 'Ver Oferta',
};

const ctaLabel = storeLabels[store] || 'Ver Oferta';

const discount = originalPrice && price
  ? Math.round((1 - parseFloat(price.replace(/[^\d]/g, '')) / parseFloat(originalPrice.replace(/[^\d]/g, ''))) * 100)
  : null;

const ratingLabel = rating
  ? rating >= 4.5 ? 'Excelente' : rating >= 4 ? 'Muito Bom' : rating >= 3.5 ? 'Bom' : 'Regular'
  : null;
---

<div class="review-card">
  {/* Header */}
  <div class="review-header">
    <span class="review-number">#{index}</span>
    <h3 class="review-name">{name}</h3>
    {badge && <span class="review-badge">{badge}</span>}
  </div>

  {/* Body */}
  <div class="review-body">
    {/* Left: Image + Score */}
    <div class="review-left">
      <div class="review-image">
        {image ? (
          <img src={image} alt={name} loading="lazy" />
        ) : (
          <div class="review-image-placeholder">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.12">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <circle cx="8.5" cy="8.5" r="1.5" fill="currentColor"/>
              <path d="M21 15l-5-5L5 21" stroke-width="1.5"/>
            </svg>
          </div>
        )}
      </div>
      {rating && (
        <div class="review-score-box">
          <div class="review-score-top">
            <span class="review-score-value">{rating.toFixed(1)}</span>
            <span class="review-score-max">/5</span>
          </div>
          <span class="review-score-label">{ratingLabel}</span>
          <RatingStars rating={rating} size="sm" />
        </div>
      )}
    </div>

    {/* Right: Info */}
    <div class="review-right">
      {description && (
        <p class="review-description">{description}</p>
      )}

      {review && (
        <div class="review-text">
          {review.split('\n\n').filter(Boolean).map((paragraph) => (
            <p>{paragraph.trim()}</p>
          ))}
        </div>
      )}

      {/* Pricing */}
      <div class="review-pricing">
        {originalPrice && <span class="review-original">De <s>{originalPrice}</s></span>}
        <div class="review-price-row">
          {price && <span class="review-price">{price}</span>}
          {discount && discount > 0 && <span class="review-discount">-{discount}% OFF</span>}
        </div>
      </div>

      {/* Pros & Cons */}
      {(pros.length > 0 || cons.length > 0) && (
        <div class="review-verdict">
          {pros.length > 0 && (
            <div class="review-list review-pros">
              <h4 class="review-list-title review-list-pros">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                O que gostamos
              </h4>
              <ul>
                {pros.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          )}
          {cons.length > 0 && (
            <div class="review-list review-cons">
              <h4 class="review-list-title review-list-cons">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                Pontos de atenção
              </h4>
              <ul>
                {cons.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          )}
        </div>
      )}

      {/* CTA */}
      <div class="review-cta-row">
        <a href={affiliateLink} class="review-cta" target="_blank" rel="sponsored noopener">
          {ctaLabel}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <span class="review-cta-trust">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Link verificado
        </span>
      </div>
    </div>
  </div>
</div>

<style>
  .review-card {
    background: var(--color-bg-pure);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    margin: var(--space-2xl) 0;
    transition: all var(--transition-base);
  }

  .review-card:hover {
    box-shadow: var(--shadow-lg);
    border-color: var(--color-border-dark);
  }

  /* Header */
  .review-header {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-xl);
    background: var(--color-bg-cool);
    border-bottom: 1px solid var(--color-border-light);
  }

  .review-number {
    font-family: var(--font-heading);
    font-size: var(--fs-lg);
    font-weight: var(--fw-extrabold);
    color: var(--color-primary);
    letter-spacing: var(--ls-tight);
  }

  .review-name {
    font-family: var(--font-heading);
    font-size: var(--fs-lg);
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-tight);
    line-height: var(--lh-snug);
    flex: 1;
  }

  .review-badge {
    padding: 0.25rem 0.75rem;
    font-size: 0.62rem;
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: var(--ls-widest);
    color: #fff;
    background: linear-gradient(135deg, var(--color-accent), var(--color-accent-dark));
    border-radius: var(--radius-full);
    white-space: nowrap;
    box-shadow: 0 2px 8px rgba(201, 162, 39, 0.2);
  }

  /* Body */
  .review-body {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 0;
  }

  /* Left */
  .review-left {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-xl);
    border-right: 1px solid var(--color-border-light);
    background: var(--color-bg);
  }

  .review-image {
    width: 100%;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-bg-cool);
  }

  .review-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-lg);
    transition: transform var(--transition-base);
  }

  .review-card:hover .review-image img {
    transform: scale(1.04);
  }

  .review-image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 120px;
  }

  .review-score-box {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    padding: var(--space-md);
    background: var(--color-bg-pure);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border-light);
  }

  .review-score-top {
    display: flex;
    align-items: baseline;
    gap: 2px;
  }

  .review-score-value {
    font-family: var(--font-heading);
    font-size: var(--fs-2xl);
    font-weight: var(--fw-extrabold);
    color: var(--color-accent);
    line-height: 1;
  }

  .review-score-max {
    font-size: var(--fs-sm);
    color: var(--color-text-faint);
    font-weight: var(--fw-medium);
  }

  .review-score-label {
    font-size: 0.62rem;
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: var(--ls-widest);
    color: var(--color-text-muted);
  }

  /* Right */
  .review-right {
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .review-description {
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
    line-height: var(--lh-relaxed);
    font-weight: var(--fw-light);
    font-style: italic;
  }

  .review-text {
    padding: var(--space-md) var(--space-lg);
    background: var(--color-bg-warm);
    border-radius: var(--radius-md);
    border-left: 3px solid var(--color-primary-lighter);
  }

  .review-text p {
    font-size: var(--fs-sm);
    color: var(--color-text-secondary);
    line-height: var(--lh-relaxed);
    font-weight: var(--fw-regular);
    margin: 0;
  }

  .review-text p + p {
    margin-top: var(--space-md);
  }

  /* Pricing */
  .review-pricing {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .review-original {
    font-size: var(--fs-xs);
    color: var(--color-text-faint);
    font-weight: var(--fw-light);
  }

  .review-price-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
  }

  .review-price {
    font-family: var(--font-heading);
    font-size: var(--fs-2xl);
    font-weight: var(--fw-extrabold);
    color: var(--color-primary);
    letter-spacing: var(--ls-tight);
    line-height: 1;
  }

  .review-discount {
    padding: 0.15rem 0.5rem;
    font-size: 0.65rem;
    font-weight: var(--fw-bold);
    color: #fff;
    background: #e74c3c;
    border-radius: var(--radius-sm);
    letter-spacing: var(--ls-wide);
  }

  /* Verdict: Pros & Cons */
  .review-verdict {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-sm);
    margin: var(--space-sm) 0;
  }

  .review-list {
    padding: var(--space-md);
    border-radius: var(--radius-md);
  }

  .review-pros {
    background: rgba(27, 67, 50, 0.04);
    border: 1px solid rgba(27, 67, 50, 0.08);
  }

  .review-cons {
    background: rgba(192, 57, 43, 0.03);
    border: 1px solid rgba(192, 57, 43, 0.08);
  }

  .review-list-title {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.68rem;
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: var(--ls-wider);
    margin-bottom: var(--space-sm);
  }

  .review-list-pros { color: var(--color-primary); }
  .review-list-cons { color: #c0392b; }

  .review-list ul {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .review-list li {
    font-size: var(--fs-xs);
    color: var(--color-text-secondary);
    line-height: var(--lh-normal);
    padding-left: var(--space-md);
    position: relative;
    font-weight: var(--fw-light);
  }

  .review-pros li::before {
    content: '+';
    position: absolute;
    left: 0;
    font-weight: var(--fw-bold);
    color: var(--color-primary);
  }

  .review-cons li::before {
    content: '–';
    position: absolute;
    left: 0;
    font-weight: var(--fw-bold);
    color: #c0392b;
  }

  /* CTA */
  .review-cta-row {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-top: var(--space-xs);
  }

  .review-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 0.75rem 1.75rem;
    font-family: var(--font-body);
    font-size: var(--fs-sm);
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    color: #fff;
    background: linear-gradient(135deg, var(--color-accent), var(--color-accent-dark));
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: all var(--transition-base);
    box-shadow: 0 3px 12px rgba(201, 162, 39, 0.25);
    position: relative;
    overflow: hidden;
  }

  .review-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, transparent 30%, rgba(255,255,255,0.2) 50%, transparent 70%);
    transform: translateX(-100%);
    transition: transform 600ms var(--ease-out-expo);
  }

  .review-cta:hover::before { transform: translateX(100%); }

  .review-cta:hover {
    color: #fff;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(201, 162, 39, 0.35);
  }

  .review-cta-trust {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.62rem;
    color: var(--color-text-faint);
    font-weight: var(--fw-light);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .review-body {
      grid-template-columns: 1fr;
    }

    .review-left {
      flex-direction: row;
      border-right: none;
      border-bottom: 1px solid var(--color-border-light);
      padding: var(--space-lg);
    }

    .review-image {
      width: 90px;
      aspect-ratio: 1;
      flex-shrink: 0;
    }

    .review-score-box {
      width: auto;
      flex: 1;
    }

    .review-verdict {
      grid-template-columns: 1fr;
    }

    .review-cta-row {
      flex-direction: column;
      align-items: stretch;
    }

    .review-cta {
      justify-content: center;
    }

    .review-cta-trust {
      justify-content: center;
    }
  }
</style>

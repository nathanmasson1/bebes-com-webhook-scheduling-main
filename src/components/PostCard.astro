---
import RatingStars from './affiliate/RatingStars.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  image?: string;
  imageAlt?: string;
  category: string;
  slug: string;
  rating?: number;
  badge?: string;
  priceRange?: string;
}

const { title, description, pubDate, image, imageAlt, category, slug, rating, badge, priceRange } = Astro.props;

const categoryLabels: Record<string, string> = {
  'gravidez': 'Gravidez',
  'recem-nascido': 'Recem-nascido',
  'sono-do-bebe': 'Sono do bebe',
  'enxoval': 'Enxoval',
  'amamentacao': 'Amamentacao',
  'rotina-familiar': 'Rotina familiar',
  'produtos-fisicos': 'Enxoval',
  'produtos-digitais': 'Rotina familiar',
  'reviews': 'Guias',
  'dicas': 'Dicas',
  'comparativos': 'Comparativos',
};

const categoryColors: Record<string, string> = {
  'gravidez': '#9f6f6a',
  'recem-nascido': '#7f9b8e',
  'sono-do-bebe': '#8a7d78',
  'enxoval': '#d6a77d',
  'amamentacao': '#b9837d',
  'rotina-familiar': '#5f7c70',
  'produtos-fisicos': '#d6a77d',
  'produtos-digitais': '#7f9b8e',
  'reviews': '#9f6f6a',
  'dicas': '#5f7c70',
  'comparativos': '#d6a77d',
};

const badgeLabels: Record<string, string> = {
  'top-pick': 'Essencial',
  'best-value': 'Pratico',
  'editor-choice': 'Favorito',
};

const formattedDate = pubDate.toLocaleDateString('pt-BR', {
  day: '2-digit',
  month: 'short',
  year: 'numeric',
});

const ratingOutOf5 = rating ? Math.round((rating / 10) * 5 * 10) / 10 : undefined;
---

<article class="post-card animate-on-scroll">
  <a href={`/${slug}`} class="post-card-link">
    <div class="post-card-image">
      {image ? (
        <img src={image} alt={imageAlt || title} loading="lazy" />
      ) : (
        <div class="post-card-placeholder">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 240" fill="none">
            <rect width="400" height="240" fill="#fff2ea"/>
            <circle cx="200" cy="104" r="30" fill="#9f6f6a" opacity="0.08"/>
            <circle cx="200" cy="104" r="15" fill="#7f9b8e" opacity="0.16"/>
            <rect x="150" y="155" width="100" height="6" rx="3" fill="#9f6f6a" opacity="0.08"/>
            <rect x="165" y="170" width="70" height="4" rx="2" fill="#7f9b8e" opacity="0.08"/>
          </svg>
        </div>
      )}
      <div class="post-card-image-overlay"></div>
      <span
        class="post-card-category"
        style={`--cat-color: ${categoryColors[category] || '#9f6f6a'}`}
      >
        {categoryLabels[category] || category || 'Guia'}
      </span>
      {badge && (
        <span class="post-card-badge">
          {badgeLabels[badge] || badge}
        </span>
      )}
    </div>

    <div class="post-card-body">
      <div class="post-card-meta">
        <time class="post-card-date" datetime={pubDate.toISOString()}>
          {formattedDate}
        </time>
        {ratingOutOf5 && (
          <span class="post-card-rating">
            <RatingStars rating={ratingOutOf5} size="sm" />
          </span>
        )}
      </div>

      <h3 class="post-card-title">{title}</h3>
      <p class="post-card-excerpt">{description}</p>

      <div class="post-card-footer">
        <span class="post-card-read-more">
          Ler guia
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </span>
        {priceRange && (
          <span class="post-card-price">{priceRange}</span>
        )}
      </div>
    </div>
  </a>
</article>

<style>
  .post-card {
    background: var(--color-bg-pure);
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--color-border-light);
    transition: all var(--transition-base);
    position: relative;
  }

  .post-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-xl);
    border-color: var(--color-border);
  }

  .post-card-link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .post-card-image {
    position: relative;
    aspect-ratio: 5 / 3;
    overflow: hidden;
    background: var(--color-bg-warm);
  }

  .post-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow), filter var(--transition-slow);
  }

  .post-card:hover .post-card-image img {
    transform: scale(1.04);
    filter: saturate(0.94) brightness(1.02);
  }

  .post-card-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-warm);
    transition: background var(--transition-base);
  }

  .post-card:hover .post-card-placeholder {
    background: var(--color-primary-surface);
  }

  .post-card-placeholder svg {
    width: 100%;
    height: 100%;
  }

  .post-card-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 50%, rgba(60, 52, 49, 0.08) 100%);
    pointer-events: none;
  }

  .post-card-category {
    position: absolute;
    top: var(--space-md);
    left: var(--space-md);
    padding: 0.3rem 0.85rem;
    font-size: 0.68rem;
    font-weight: var(--fw-semibold);
    color: var(--cat-color);
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.6);
    border-radius: var(--radius-full);
    text-transform: uppercase;
    letter-spacing: var(--ls-wider);
  }

  .post-card-badge {
    position: absolute;
    top: var(--space-md);
    right: var(--space-md);
    padding: 0.3rem 0.75rem;
    font-size: 0.6rem;
    font-weight: var(--fw-bold);
    color: #fff;
    background: linear-gradient(135deg, var(--color-accent), var(--color-accent-dark));
    border-radius: var(--radius-full);
    text-transform: uppercase;
    letter-spacing: var(--ls-wider);
    box-shadow: var(--shadow-gold);
  }

  .post-card-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: var(--space-xl) var(--space-xl) var(--space-lg);
  }

  .post-card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
    flex-wrap: wrap;
  }

  .post-card-date {
    font-size: var(--fs-xs);
    color: var(--color-text-faint);
    text-transform: uppercase;
    letter-spacing: var(--ls-wide);
  }

  .post-card-rating {
    display: flex;
    align-items: center;
  }

  .post-card-title {
    font-family: var(--font-heading);
    font-size: var(--fs-xl);
    font-weight: var(--fw-bold);
    margin-bottom: var(--space-sm);
    line-height: var(--lh-snug);
    color: var(--color-text);
    letter-spacing: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color var(--transition-fast);
  }

  .post-card:hover .post-card-title {
    color: var(--color-primary);
  }

  .post-card-excerpt {
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
    line-height: var(--lh-relaxed);
    margin-bottom: var(--space-lg);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-weight: var(--fw-light);
    flex: 1;
  }

  .post-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border-light);
  }

  .post-card-read-more {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--fs-sm);
    font-weight: var(--fw-semibold);
    color: var(--color-primary);
    letter-spacing: var(--ls-wide);
    transition: gap var(--transition-fast);
  }

  .post-card:hover .post-card-read-more {
    gap: var(--space-md);
  }

  .post-card-price {
    font-size: var(--fs-xs);
    font-weight: var(--fw-semibold);
    color: var(--color-accent-dark);
    background: var(--color-accent-surface);
    padding: 0.2rem 0.65rem;
    border-radius: var(--radius-full);
    letter-spacing: var(--ls-wide);
  }
</style>

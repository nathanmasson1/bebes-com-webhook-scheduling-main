---
import { getCollection } from 'astro:content';
import PostCard from './PostCard.astro';
import { isPostPublic } from '../lib/postVisibility';

interface Props {
  data?: any;
  limit?: number;
}

const d = Astro.props.data || {};
const limit = d.limit || Astro.props.limit || 6;
const label = d.label || 'Blog';
const title = d.title || 'Últimos Posts';
const subtitle = d.subtitle || 'Confira nossos reviews mais recentes, dicas e comparativos para fazer as melhores escolhas.';
const ctaText = d.ctaText || 'Ver Todos os Posts';
const ctaHref = d.ctaHref || '/blog';

const posts = (await getCollection('blog', ({ data }) => isPostPublic(data)))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, limit);
---

<section class="posts-section section" id="posts">
  <div class="container">
    <div class="section-header animate-on-scroll">
      <span class="section-label">{label}</span>
      <h2 class="section-title">{title}</h2>
      <p class="section-subtitle">{subtitle}</p>
    </div>

    <div class="posts-grid stagger-children animate-on-scroll">
      {posts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          image={post.data.image}
          imageAlt={post.data.imageAlt}
          category={post.data.category}
          slug={post.id}
          rating={post.data.rating}
          badge={post.data.badge}
          priceRange={post.data.priceRange}
        />
      ))}
    </div>

    <div class="posts-cta animate-on-scroll">
      <div class="divider">
        <div class="divider-icon"></div>
      </div>
      <a href={ctaHref} class="btn btn-outline">
        {ctaText}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .posts-section {
    background: var(--color-bg-warm);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
    margin-bottom: var(--space-2xl);
  }

  .posts-cta {
    text-align: center;
  }

  @media (max-width: 1024px) {
    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .posts-grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }
  }
</style>
